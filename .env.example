# ============================================================
# Copia este archivo como `.env` y rellena los valores con los
# de tu proyecto de Supabase (Settings → API).
#
# La "anon key" es pública por diseño (la seguridad real la dan
# las políticas RLS de la base de datos), pero el archivo .env
# nunca se sube al repositorio.
# ============================================================
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...tu-anon-key...

# Módulo Prospector — Google Places API (New)
# Crea una clave en Google Cloud Console → APIs y servicios → Credenciales
# Activa "Places API (New)" en tu proyecto de Google Cloud
# Restringe la clave a tu dominio en producción (HTTP referrers)
VITE_GOOGLE_PLACES_API_KEY=
